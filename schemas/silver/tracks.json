{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "additionalProperties": false,
  "properties": {
    "track_id": {
      "title": "Track Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "popularity": {
      "maximum": 100,
      "minimum": 0,
      "title": "Popularity",
      "type": "integer"
    },
    "duration_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Ms"
    },
    "explicit": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Explicit"
    },
    "primary_artist_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Primary Artist Id"
    },
    "primary_artist_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Primary Artist Name"
    },
    "album_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Album Id"
    },
    "album_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Album Name"
    },
    "release_date": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Release Date"
    }
  },
  "required": [
    "track_id",
    "name",
    "popularity"
  ],
  "title": "SilverTrack",
  "type": "object"
}
