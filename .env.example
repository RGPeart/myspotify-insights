# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_STORAGE_CONTAINER_NAME=spotify-data

# Azure Monitor (optional — forward structured logs to Azure Application Insights)
# Obtain from Azure Portal → Application Insights → Connection String
AZURE_MONITOR_CONNECTION_STRING=your_connection_string_here

# Database (if using Azure SQL)
DB_CONNECTION_STRING=your_db_connection_string_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Airflow Configuration
PYTHONPATH=/opt/airflow
# Generate the AIRFLOW_UID with: 
#   echo "AIRFLOW_UID=$(id -u)"
AIRFLOW_UID=50000
# Generate a valid Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
# Generate a JWT secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API_AUTH__JWT_SECRET=your_jwt_secret_here

# OpenLineage / Marquez (used by Airflow when --profile lineage is active)
OPENLINEAGE_URL=http://marquez:5000
OPENLINEAGE_NAMESPACE=myspotify-insights
WEB_PORT=3000

# Google Gemini API Key
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Anthropic API Configuration (to connect to Google Gemini via Litellm)
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=DUMMY_KEY
# ANTHROPIC_AUTH_TOKEN=DUMMY_KEY
# ANTHROPIC_MODEL=gemini-2.5-flash